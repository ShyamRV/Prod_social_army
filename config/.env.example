# ══════════════════════════════════════════════════════════════
# AI Social Media Army - Environment Configuration
# Copy this to config/.env and fill in all values
# ══════════════════════════════════════════════════════════════

# ── App ───────────────────────────────────────────────────────
APP_NAME="AI Social Media Army"
APP_VERSION="2.0.0"
DEBUG=false
PUBLIC_BASE_URL=https://your-railway-or-render-url.com

# ── Database (Supabase) ───────────────────────────────────────
# Get from: https://supabase.com → Project Settings → Database
DATABASE_URL=postgresql+asyncpg://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# ── Cloudflare R2 (Video Storage) ────────────────────────────
# Get from: Cloudflare Dashboard → R2 → Manage R2 API Tokens
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY=your-r2-access-key
R2_SECRET_KEY=your-r2-secret-key
R2_BUCKET_NAME=social-army-videos
R2_PUBLIC_URL=https://pub-XXXXXXXX.r2.dev

# ── Security ──────────────────────────────────────────────────
SECRET_KEY=generate-with-openssl-rand-hex-32
# Generate Fernet key: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your-fernet-key-here
AGENT_SECRET=shared-secret-between-backend-and-agents

# ── Fetch.ai / ASI:ONE ────────────────────────────────────────
# Get ASI1 API key: https://asi1.ai/dashboard/api-keys
ASI1_API_KEY=sk-asi1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Get Agentverse API key: https://agentverse.ai → Settings → API Keys
AGENTVERSE_API_KEY=your-agentverse-api-key

# Public URL of the FastAPI backend (agents call /jobs, /auth callbacks)
BACKEND_URL=https://your-railway-or-render-url.com

# ── Agent Addresses ───────────────────────────────────────────
# After setting seeds, run: python tools/print_agent_addresses.py
# Or read startup logs: "Starting agent with address: agent1q..."
GATE_AGENT_ADDRESS=agent1q_FILL_AFTER_DEPLOY
ORCHESTRATOR_AGENT_ADDRESS=agent1q_FILL_AFTER_DEPLOY
CONTENT_AGENT_ADDRESS=agent1q_FILL_AFTER_DEPLOY
YOUTUBE_AGENT_ADDRESS=agent1q_FILL_AFTER_DEPLOY
LINKEDIN_AGENT_ADDRESS=agent1q_FILL_AFTER_DEPLOY
SIM_AGENT_ADDRESS=

# Agent seeds (use different unique phrases for each)
GATE_AGENT_SEED=my-gate-seed-phrase-unique-v1
ORCHESTRATOR_SEED=my-orchestrator-seed-phrase-unique-v1
CONTENT_AGENT_SEED=my-content-agent-seed-phrase-unique-v1
YOUTUBE_AGENT_SEED=my-youtube-agent-seed-phrase-unique-v1
LINKEDIN_AGENT_SEED=my-linkedin-agent-seed-phrase-unique-v1
SIM_AGENT_SEED=local-sim-seed-v1

# ── uAgents: local process / Docker vs Agentverse ─────────────
# Local multi-process (run_all.py): USE_MAILBOX=false, omit *_SUBMIT_URL (defaults to 127.0.0.1).
# Agentverse / ASI:ONE: USE_MAILBOX=true and set each agent's public .../submit URL.
USE_MAILBOX=false
GATE_AGENT_PORT=8001
ORCHESTRATOR_AGENT_PORT=8002
CONTENT_AGENT_PORT=8003
YOUTUBE_AGENT_PORT=8004
LINKEDIN_AGENT_PORT=8005
SIM_AGENT_PORT=8010
GATE_SUBMIT_URL=
ORCHESTRATOR_SUBMIT_URL=
CONTENT_SUBMIT_URL=
YOUTUBE_SUBMIT_URL=
LINKEDIN_SUBMIT_URL=
SIM_SUBMIT_URL=

# ── Google / YouTube OAuth ────────────────────────────────────
# Get from: https://console.cloud.google.com → APIs → Credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://your-domain.com/auth/youtube/callback

# ── LinkedIn OAuth ────────────────────────────────────────────
# Get from: https://www.linkedin.com/developers/apps → Auth
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret
LINKEDIN_REDIRECT_URI=https://your-domain.com/auth/linkedin/callback

# ── Rate Limiting ─────────────────────────────────────────────
RATE_LIMIT_PER_USER_PER_HOUR=10
