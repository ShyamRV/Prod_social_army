LINKEDIN_AGENT_SEED=linkedin_Z2wX4_2026_unique

# ── Google / YouTube OAuth ────────────────────────────────────
# Get from: https://console.cloud.google.com → APIs → Credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://your-domain.com/auth/youtube/callback

# ── LinkedIn OAuth ────────────────────────────────────────────
# Get from: https://www.linkedin.com/developers/apps → Auth
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret
LINKEDIN_REDIRECT_URI=https://your-domain.com/auth/linkedin/callback

# ── Rate Limiting ─────────────────────────────────────────────
RATE_LIMIT_PER_USER_PER_HOUR=10


BACKEND_URL=https://prod-social-army.onrender.com

USE_MAILBOX=false

