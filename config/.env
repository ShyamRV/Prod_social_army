# ══════════════════════════════════════════════════════════════
# AI Social Media Army - Environment Configuration
# Copy this to config/.env and fill in all values
# ══════════════════════════════════════════════════════════════

# ── App ───────────────────────────────────────────────────────
APP_NAME="AI Social Media Army"
APP_VERSION="2.0.0"
DEBUG=false
PUBLIC_BASE_URL=https://your-railway-or-render-url.com

# ── Database (SQLite for local dev) ───────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./social_army.db

# ── Cloudflare R2 (Video Storage) ────────────────────────────
# Get from: Cloudflare Dashboard → R2 → Manage R2 API Tokens
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY=your-r2-access-key
R2_SECRET_KEY=your-r2-secret-key
R2_BUCKET_NAME=social-army-videos
R2_PUBLIC_URL=https://pub-XXXXXXXX.r2.dev

# ── Security ──────────────────────────────────────────────────
SECRET_KEY=generate-with-openssl-rand-hex-32
# Generate Fernet key: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Leave empty for local dev (a process-local key will be generated).
ENCRYPTION_KEY=
AGENT_SECRET=KLOLust8KQaBqAZiwNE5BPkAVHa/6B6xhHmNloh/LV0=

# ── Fetch.ai / ASI:ONE ────────────────────────────────────────
# Get ASI1 API key: https://asi1.ai/dashboard/api-keys
ASI1_API_KEY=sk_c7fd95bbb31f435eac701619fa4f736b7733d11ac76a4dc3a25d8e5b4647a68b
# Get Agentverse API key: https://agentverse.ai → Settings → API Keys
AGENTVERSE_API_KEY=your-agentverse-api-key

# ── Agent Addresses ───────────────────────────────────────────
# Fill these AFTER deploying each agent to Agentverse
# You get these from agent logs: "Starting agent with address: agent1q..."
ORCHESTRATOR_AGENT_ADDRESS=agent1qtrvzyusagh3cmvmtt7u5xe8jsn6zwextmlsz2vrp0ym2euvkn4wq2jxkrg
CONTENT_AGENT_ADDRESS=agent1qttrc6zywpcj62tgxa5gh0q4p7r7p6tr3tk6xhgwr53wug7n88nf6xa40jp
YOUTUBE_AGENT_ADDRESS=agent1qf5rzmq33wu8e6lr6dg75m5czeapeze0tje32009a6kzs4d47df9gddfnsm
LINKEDIN_AGENT_ADDRESS=agent1q2zzkx6zmpxwk0zca37zflav639phlpwqukn4gytyxdwq3lk3hxsj5uc5s3

# Agent seeds (use different unique phrases for each)
GATE_AGENT_SEED=gate_9xA7pL_2026_unique
ORCHESTRATOR_SEED=orch_B3kLm2_2026_unique
CONTENT_AGENT_SEED=content_M9pQ1_2026_unique
